# ============================================================
# BACKEND — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE COMMITTEZ JAMAIS le fichier .env !
# ============================================================

# Serveur
PORT=5000
NODE_ENV=development   # Mettre "production" sur Render

# Base de données SQLite (développement local)
# En production sur Render, remplacer par la config MySQL ci-dessous
# DB_HOST=your-mysql-host.render.com
# DB_PORT=3306
# DB_NAME=gestion_files
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Authentification JWT
# Générer une clé forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACER_PAR_UN_SECRET_FORT_MIN_64_CHARS

# URL du Frontend (pour CORS et liens dans les emails)
FRONTEND_URL=http://localhost:3000

# Email SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre-adresse@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_application_google
EMAIL_FROM="Hôpital de Kyeshero" <no-reply@hopital-kyeshero.com>

# Web Push VAPID
# Générer des clés : node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=BL3ExeIgCM0BPXMksDkOOhVBJyWN12gi474zr8a1XAznn_W_QXTNjhibHHRSAq2oYT20o0trpT7SPF6iQYE1pG0
VAPID_PRIVATE_KEY=_2GOP_6ETOdxqdCjnMFBTxuc2tCD84VAMT-OsgTpyJE
VAPID_MAILTO=mailto:admin@hopital-kyeshero.com
